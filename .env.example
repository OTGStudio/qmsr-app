# Supabase (local: run `npx supabase status` after `supabase start`)
# VITE_SUPABASE_URL=http://localhost:54321
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe (publishable key only — never put secret keys in Vite env)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# App URL (used for redirects, CORS, etc.)
# VITE_APP_URL=http://localhost:5173

# FEI establishment verification: use mock provider (deterministic) instead of provisional openFDA-adjacent stub
# VITE_FEI_MOCK=true
